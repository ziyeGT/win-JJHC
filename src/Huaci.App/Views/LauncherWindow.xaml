<Window x:Class="Huaci.App.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Huaci"
        Width="292" Height="156"
        MinWidth="292" MinHeight="156"
        MaxWidth="292" MaxHeight="156"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CompactWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="WindowShell"
            Background="{StaticResource PanelBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="11">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>

                <Border x:Name="HeaderDragArea"
                        Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <DockPanel Margin="12,0,4,0" LastChildFill="True">
                        <Ellipse x:Name="HeaderStatusDot"
                                 Width="7" Height="7"
                                 Margin="0,0,9,0"
                                 Fill="{StaticResource SuccessBrush}"
                                 VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Huaci"
                                       FontSize="13.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="7,1,0,0"
                                       Text="极简划词"
                                       FontSize="9.5"
                                       Foreground="{StaticResource TextWeakBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ToggleButton x:Name="PinButton"
                              Grid.Column="1"
                              Style="{StaticResource HeaderIconToggle}"
                              ToolTip="置顶"
                              AutomationProperties.Name="置顶主窗口"
                              Checked="PinButton_OnChanged"
                              Unchecked="PinButton_OnChanged">
                    <TextBlock Text="&#xE718;" FontFamily="{StaticResource IconFont}" FontSize="13" />
                </ToggleButton>

                <Button x:Name="MinimizeButton"
                        Grid.Column="2"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="最小化到托盘"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="最小化到托盘"
                        AutomationProperties.HelpText="隐藏主窗口，程序继续在系统托盘运行"
                        Click="HideButton_OnClick">
                    <TextBlock Text="&#xE921;" FontFamily="{StaticResource IconFont}" FontSize="11" />
                </Button>

                <Button x:Name="HideButton"
                        Grid.Column="3"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="隐藏到托盘"
                        AutomationProperties.Name="隐藏主窗口"
                        Click="HideButton_OnClick">
                    <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="12" />
                </Button>
            </Grid>

            <UniformGrid x:Name="ModuleGrid"
                         Grid.Row="1"
                         Rows="1" Columns="3"
                         Margin="8,2,8,8">
                <ToggleButton x:Name="AutoCaptureModuleButton"
                              Style="{StaticResource ModuleToggle}"
                              ToolTip="开启或暂停自动划词"
                              ToolTipService.InitialShowDelay="350"
                              AutomationProperties.Name="自动划词"
                              Click="AutoCaptureModuleButton_OnClick">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="AutoCaptureIcon"
                                       Text="&#xE8B0;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="27"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="划词"
                                       FontSize="10.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Ellipse x:Name="AutoCaptureModuleDot"
                                 Width="6" Height="6"
                                 Margin="0,6,7,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Fill="{StaticResource SuccessBrush}" />
                    </Grid>
                </ToggleButton>

                <Button x:Name="ManualTranslationModuleButton"
                        Style="{StaticResource ModuleButton}"
                        ToolTip="打开手动翻译"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="手动翻译"
                        Click="ManualTranslationModuleButton_OnClick">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE774;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="27"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="翻译"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button x:Name="SettingsModuleButton"
                        Style="{StaticResource ModuleButton}"
                        ToolTip="打开全部设置"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="设置"
                        Click="SettingsModuleButton_OnClick">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="27"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="设置"
                                       FontSize="10.5"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Ellipse x:Name="SettingsModuleDot"
                                 Width="6" Height="6"
                                 Margin="0,6,7,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Fill="{StaticResource WarningBrush}" />
                    </Grid>
                </Button>
            </UniformGrid>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="1"
                       Width="0" Height="0"
                       Opacity="0"
                       IsHitTestVisible="False"
                       AutomationProperties.LiveSetting="Polite" />
        </Grid>
    </Border>
</Window>
