<Window x:Class="Huaci.App.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Huaci"
        Width="256" Height="162"
        MinWidth="256" MinHeight="162"
        MaxWidth="256" MaxHeight="162"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CompactWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="WindowShell"
            Background="{StaticResource PanelBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="11">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>

                <Border x:Name="HeaderDragArea"
                        Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <DockPanel Margin="11,0,3,0" LastChildFill="True">
                        <Ellipse x:Name="HeaderStatusDot"
                                 Width="6" Height="6"
                                 Margin="0,0,8,0"
                                 Fill="{StaticResource SuccessBrush}"
                                 VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Huaci"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="6,1,0,0"
                                       Text="极简划词"
                                       FontSize="9"
                                       Foreground="{StaticResource TextWeakBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ToggleButton x:Name="PinButton"
                              Grid.Column="1"
                              Style="{StaticResource HeaderIconToggle}"
                              IsChecked="True"
                              IsHitTestVisible="False"
                              Focusable="False"
                              ToolTip="主窗口常驻置顶"
                              AutomationProperties.Name="主窗口已常驻置顶">
                    <TextBlock Text="&#xE718;" FontFamily="{StaticResource IconFont}" FontSize="13" />
                </ToggleButton>

                <Button x:Name="MinimizeButton"
                        Grid.Column="2"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="最小化到托盘"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="最小化到托盘"
                        AutomationProperties.HelpText="隐藏主窗口，程序继续在系统托盘运行"
                        Click="HideButton_OnClick">
                    <TextBlock Text="&#xE921;" FontFamily="{StaticResource IconFont}" FontSize="11" />
                </Button>

                <Button x:Name="HideButton"
                        Grid.Column="3"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="隐藏到托盘"
                        AutomationProperties.Name="隐藏主窗口"
                        Click="HideButton_OnClick">
                    <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="12" />
                </Button>
            </Grid>

            <UniformGrid x:Name="ModuleGrid"
                         Grid.Row="1"
                         Rows="0" Columns="4"
                         Margin="7,1,7,7">
                <ToggleButton x:Name="AutoCaptureModuleButton"
                              Style="{StaticResource ModuleToggle}"
                              ToolTip="开启或暂停自动划词"
                              ToolTipService.InitialShowDelay="350"
                              AutomationProperties.Name="自动划词"
                              Click="AutoCaptureModuleButton_OnClick">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border x:Name="AutoCaptureIconBadge"
                                    Width="30" Height="30"
                                    Background="#244F6BED"
                                    BorderBrush="#607F91FF"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="AutoCaptureIcon"
                                           Text="译"
                                           FontFamily="Microsoft YaHei UI"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Margin="0,4,0,0"
                                       Text="划词"
                                       FontSize="9.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Ellipse x:Name="AutoCaptureModuleDot"
                                 Width="5" Height="5"
                                 Margin="0,5,5,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Fill="{StaticResource SuccessBrush}" />
                    </Grid>
                </ToggleButton>

                <Button x:Name="ManualTranslationModuleButton"
                        Style="{StaticResource ModuleButton}"
                        ToolTip="打开手动翻译"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="手动翻译"
                        Click="ManualTranslationModuleButton_OnClick">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE774;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="23"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="翻译"
                                   FontSize="9.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button x:Name="ScreenshotTranslationModuleButton"
                        Style="{StaticResource ModuleButton}"
                        ToolTip="按住 Ctrl+Alt+左键直接拖动，松开完成"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="截图翻译"
                        Click="ScreenshotTranslationModuleButton_OnClick">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE91B;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="23"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="截图"
                                   FontSize="9.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button x:Name="QuickNotebookModuleButton"
                        Style="{StaticResource ModuleButton}"
                        ToolTip="打开快速笔记，保存剪贴板文字或图片"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="快速笔记"
                        Click="QuickNotebookModuleButton_OnClick">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE70B;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="23"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="笔记"
                                   FontSize="9.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button x:Name="SettingsModuleButton"
                        Style="{StaticResource ModuleButton}"
                        ToolTip="打开全部设置"
                        ToolTipService.InitialShowDelay="350"
                        AutomationProperties.Name="设置"
                        Click="SettingsModuleButton_OnClick">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="23"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="设置"
                                       FontSize="9.5"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Ellipse x:Name="SettingsModuleDot"
                                 Width="5" Height="5"
                                 Margin="0,5,5,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Fill="{StaticResource WarningBrush}" />
                    </Grid>
                </Button>
            </UniformGrid>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="1"
                       Width="0" Height="0"
                       Opacity="0"
                       IsHitTestVisible="False"
                       AutomationProperties.LiveSetting="Polite" />
        </Grid>
    </Border>
</Window>
