<Window x:Class="Huaci.App.Views.QuickNotebookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Huaci 快速笔记"
        Width="326" Height="410"
        MinWidth="326" MinHeight="410"
        MaxWidth="326" MaxHeight="410"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        AllowDrop="True"
        Loaded="Window_OnLoaded"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDragLeave="Window_OnPreviewDragLeave"
        PreviewDrop="Window_OnPreviewDrop">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CompactWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="HistoryListItem" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Margin" Value="0,0,0,5" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Focusable" Value="True" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="ItemChrome"
                                    Padding="7"
                                    Background="{StaticResource FieldBrush}"
                                    BorderBrush="{StaticResource MainBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemChrome" Property="Background" Value="#F441454B" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemChrome" Property="Background" Value="#473F4868" />
                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#918397FF" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource SettingsPanelBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="10">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="23" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <StackPanel Margin="11,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE70B;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="14"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Margin="7,0,0,0"
                                   Text="快速笔记"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="6,1,0,0"
                                   Text="文字与图片"
                                   FontSize="9"
                                   Foreground="{StaticResource TextWeakBrush}" />
                    </StackPanel>
                </Border>
                <Button Grid.Column="1"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="打开 save 文件夹"
                        AutomationProperties.Name="打开快速笔记保存文件夹"
                        Click="OpenFolderButton_OnClick">
                    <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="11" />
                </Button>
                <Button Grid.Column="2"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="刷新历史"
                        AutomationProperties.Name="刷新快速笔记历史"
                        Click="RefreshButton_OnClick">
                    <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="11" />
                </Button>
                <Button Grid.Column="3"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="关闭"
                        AutomationProperties.Name="关闭快速笔记"
                        Click="HideButton_OnClick">
                    <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="11" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="9,2,9,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="122" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource SectionCard}"
                        Padding="8"
                        Background="#F23A3D43"
                        BorderBrush="#3D8397FF">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="30" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Border x:Name="NewNoteIconBorder"
                                        Width="18" Height="18"
                                        Background="#328397FF"
                                        CornerRadius="5">
                                    <TextBlock Text="&#xE70B;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="9"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Margin="6,1,0,0"
                                           Text="新建笔记"
                                           FontSize="10.2"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <Button x:Name="AlarmButton"
                                    Grid.Column="1"
                                    Height="18"
                                    MinHeight="18"
                                    Margin="8,0,0,0"
                                    Padding="6,0"
                                    Content="设置闹铃"
                                    FontSize="8.5"
                                    Foreground="{StaticResource WarningBrush}"
                                    ToolTip="使用当前编辑文字或所选文字笔记设置闹铃"
                                    AutomationProperties.Name="为快速笔记设置闹铃"
                                    Click="AlarmButton_OnClick" />
                            <Border Grid.Column="3"
                                    Height="18"
                                    Padding="6,0"
                                    Background="#22FFFFFF"
                                    CornerRadius="9">
                                <TextBlock Text="Ctrl+V 图片 · 可拖入"
                                           FontSize="8.2"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,2,0,0">
                            <TextBox x:Name="EditorTextBox"
                                     Height="Auto"
                                     Padding="8,5"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="EditorTextBox_OnTextChanged"
                                     AutomationProperties.Name="快速笔记文字内容"
                                     ToolTip="粘贴文字后按 Ctrl+Enter 保存；粘贴图片会直接保存" />
                            <TextBlock x:Name="EditorPlaceholderTextBlock"
                                       Margin="9,6,8,0"
                                       Text="输入或粘贴文字…"
                                       FontSize="9.2"
                                       Foreground="{StaticResource TextWeakBrush}"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Top" />
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="68" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Text="Ctrl+Enter"
                                       FontSize="8.4"
                                       Foreground="{StaticResource TextWeakBrush}" />
                            <Button x:Name="PasteSaveButton"
                                    Grid.Column="1"
                                    Height="26"
                                    MinHeight="26"
                                    Padding="4,2"
                                    Content="粘贴保存"
                                    FontSize="9.2"
                                    ToolTip="自动识别剪贴板中的文字或图片"
                                    Click="PasteSaveButton_OnClick" />
                            <Button x:Name="SaveTextButton"
                                    Grid.Column="3"
                                    Height="26"
                                    MinHeight="26"
                                    Padding="4,2"
                                    Style="{StaticResource AccentButton}"
                                    Content="保存文字"
                                    FontSize="9.2"
                                    Click="SaveTextButton_OnClick" />
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="52" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="历史"
                                   FontSize="10.2"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="HistoryCountTextBlock"
                                   Margin="5,0,0,0"
                                   Text="0 条"
                                   FontSize="9"
                                   Foreground="{StaticResource TextWeakBrush}" />
                    </StackPanel>
                    <Button x:Name="CopyButton"
                            Grid.Column="1"
                            Height="24"
                            MinHeight="24"
                            Padding="4,1"
                            Content="复制"
                            FontSize="9.2"
                            IsEnabled="False"
                            Click="CopyButton_OnClick" />
                    <Button x:Name="DeleteButton"
                            Grid.Column="3"
                            Height="24"
                            MinHeight="24"
                            Padding="4,1"
                            Content="删除"
                            FontSize="9.2"
                            IsEnabled="False"
                            Click="DeleteButton_OnClick" />
                </Grid>

                <Grid Grid.Row="2">
                    <ListBox x:Name="HistoryListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemContainerStyle="{StaticResource HistoryListItem}"
                             SelectionChanged="HistoryListBox_OnSelectionChanged"
                             MouseDoubleClick="HistoryListBox_OnMouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38" Height="38"
                                            Background="#20FFFFFF"
                                            BorderBrush="#24FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       Visibility="{Binding IconVisibility}"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{Binding Thumbnail}"
                                                   Visibility="{Binding ThumbnailVisibility}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="7,0,5,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Preview}"
                                                   FontSize="9.8"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,3,0,0"
                                                   Text="{Binding Detail}"
                                                   FontSize="8.5"
                                                   Foreground="{StaticResource TextWeakBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TimeText}"
                                               FontSize="8.3"
                                               Foreground="{Binding TimeBrush}"
                                               VerticalAlignment="Top" />
                                    <Button Grid.Column="2"
                                            Width="25"
                                            Height="22"
                                            MinHeight="22"
                                            Padding="3"
                                            Tag="{Binding Alarm}"
                                            Visibility="{Binding AlarmBadgeVisibility}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Background="#35F1B84B"
                                            BorderBrush="#82F1B84B"
                                            ToolTip="{Binding AlarmToolTip}"
                                            AutomationProperties.Name="查看闹铃详情"
                                            Click="AlarmBadgeButton_OnClick">
                                        <TextBlock Text="&#xE823;"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource WarningBrush}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel x:Name="EmptyStatePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE70B;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="22"
                                   Foreground="{StaticResource TextWeakBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="还没有笔记"
                                   FontSize="9.8"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="Ctrl+V 或拖入图片，内容只保存在本地"
                                   FontSize="8.2"
                                   Foreground="{StaticResource TextWeakBrush}" />
                    </StackPanel>
                </Grid>

                <Border x:Name="DropHintBorder"
                        Grid.RowSpan="3"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Background="#EA30343B"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1.5"
                        CornerRadius="9">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="42" Height="42"
                                Background="#328397FF"
                                CornerRadius="12">
                            <TextBlock Text="&#xE898;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="19"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Margin="0,9,0,0"
                                   Text="松开即可保存到快速笔记"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="支持文字与常见图片格式"
                                   FontSize="8.5"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="#48000000"
                    CornerRadius="0,0,9,9"
                    Padding="9,0">
                <TextBlock x:Name="StatusTextBlock"
                           Text="内容保存在本地 save 文件夹"
                           FontSize="8.8"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
            </Border>
        </Grid>
    </Border>
</Window>
