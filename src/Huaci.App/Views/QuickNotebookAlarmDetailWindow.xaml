<Window x:Class="Huaci.App.Views.QuickNotebookAlarmDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Huaci 闹铃详情"
        Width="300" Height="226"
        MinWidth="300" MinHeight="226"
        MaxWidth="300" MaxHeight="226"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CompactWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource SettingsPanelBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="10">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="23" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <StackPanel Margin="11,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE823;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="14"
                                   Foreground="{StaticResource WarningBrush}" />
                        <TextBlock Margin="7,0,0,0"
                                   Text="闹铃详情"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="6,1,0,0"
                                   Text="本地提醒"
                                   FontSize="9"
                                   Foreground="{StaticResource TextWeakBrush}" />
                    </StackPanel>
                </Border>
                <Button Grid.Column="1"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="关闭"
                        AutomationProperties.Name="关闭闹铃详情"
                        Click="CloseButton_OnClick">
                    <TextBlock Text="&#xE711;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="11" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="9,2,9,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="38" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SectionCard}"
                        Padding="9">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="31" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="提醒内容"
                                   FontSize="9.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,3,0,5"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="AlarmMessageTextBlock"
                                       TextWrapping="Wrap"
                                       FontSize="9.6"
                                       LineHeight="15"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       AutomationProperties.Name="闹铃提醒内容" />
                        </ScrollViewer>
                        <Border Grid.Row="2"
                                Padding="7,0"
                                Background="#27F1B84B"
                                BorderBrush="#55F1B84B"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE823;"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource WarningBrush}" />
                                <TextBlock x:Name="AlarmDueTimeTextBlock"
                                           Margin="6,0,0,0"
                                           FontSize="9.2"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}"
                                           AutomationProperties.Name="闹铃具体时间" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,7,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="78" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Height="28"
                            MinHeight="28"
                            Content="保留"
                            FontSize="9.3"
                            Click="CloseButton_OnClick" />
                    <Button x:Name="CancelAlarmButton"
                            Grid.Column="3"
                            Height="28"
                            MinHeight="28"
                            Padding="5,2"
                            Content="取消闹铃"
                            FontSize="9.3"
                            Foreground="{StaticResource ErrorBrush}"
                            AutomationProperties.Name="取消当前闹铃"
                            Click="CancelAlarmButton_OnClick" />
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Background="#48000000"
                    CornerRadius="0,0,9,9"
                    Padding="9,0">
                <TextBlock x:Name="AlarmDetailStatusTextBlock"
                           Text="闹铃保存在本地 save\alarms.json"
                           FontSize="8.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
            </Border>
        </Grid>
    </Border>
</Window>
