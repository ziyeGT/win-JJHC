<Window x:Class="Huaci.App.Views.AlarmBannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Focusable="False"
        Width="800"
        Height="108"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="ReminderCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Margin" Value="7,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ToolTip" Value="关闭提醒" />
            <Setter Property="automation:AutomationProperties.Name" Value="关闭提醒" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Background"
                                        Value="#FFE76767" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Background"
                                        Value="#FFC94D4D" />
                                <Setter TargetName="Chrome"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Chrome"
                                        Property="RenderTransformOrigin"
                                        Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- A null-background canvas leaves the rest of the full-width host
         visually transparent. Native hit testing also passes those pixels
         through to the application below this window. -->
    <Canvas x:Name="RootCanvas"
            Background="{x:Null}"
            ClipToBounds="True">
        <Grid x:Name="FlightAssembly"
              Canvas.Left="0"
              Canvas.Top="12"
              Height="70"
              VerticalAlignment="Top"
              MouseEnter="FlightAssembly_OnMouseEnter"
              MouseLeave="FlightAssembly_OnMouseLeave">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="FlightTranslate" />
            </Grid.RenderTransform>
            <Grid.Effect>
                <DropShadowEffect BlurRadius="12"
                                  Direction="270"
                                  ShadowDepth="3"
                                  Opacity="0.31"
                                  Color="#FF111521" />
            </Grid.Effect>

            <!-- The aircraft leads on the right while the message banner
                 trails behind it on the left. -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="94" />
            </Grid.ColumnDefinitions>

            <Border x:Name="BannerCard"
                    Grid.Column="0"
                    Height="48"
                    VerticalAlignment="Center"
                    BorderBrush="#8B6F8EFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    RenderTransformOrigin="0.94,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <RotateTransform x:Name="BannerSwayRotate" />
                        <TranslateTransform x:Name="BannerBobTranslate" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F22A3040" Offset="0" />
                        <GradientStop Color="#F2343B4D" Offset="0.72" />
                        <GradientStop Color="#F22B3140" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0"
                             Width="8"
                             Height="8"
                             Margin="13,0,10,0"
                             VerticalAlignment="Center"
                             Fill="#FFFFC75C" />

                    <TextBlock x:Name="MessageTextBlock"
                               Grid.Column="1"
                               Width="380"
                               VerticalAlignment="Center"
                               Foreground="#FFF7F8FC"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               automation:AutomationProperties.LiveSetting="Assertive"
                               automation:AutomationProperties.Name="闹铃提醒内容" />

                    <Button x:Name="CloseReminderButton"
                            Grid.Column="2"
                            Style="{StaticResource ReminderCloseButtonStyle}"
                            Click="CloseReminderButton_OnClick">
                        <Viewbox Width="10" Height="10">
                            <Path Fill="White"
                                  Data="M2,0 L5,3 L8,0 L10,2 L7,5 L10,8 L8,10 L5,7 L2,10 L0,8 L3,5 L0,2 Z" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  Width="24"
                  Height="54"
                  VerticalAlignment="Center">
                <Path Stroke="#8EAFC6FF"
                      StrokeThickness="1.4"
                      Data="M0,21 L24,27 M0,37 L24,31" />
                <Path x:Name="TowLineGlow"
                      Stroke="#DCE8EEFF"
                      StrokeThickness="1.1"
                      StrokeDashArray="2,3"
                      Data="M0,21 L24,27 M0,37 L24,31" />
                <Ellipse Width="5"
                         Height="5"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Fill="#FFDDE6FF" />
            </Grid>

            <Grid x:Name="PlaneVisual"
                  Grid.Column="2"
                  Width="92"
                  Height="58"
                  VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <RotateTransform x:Name="PlanePitchRotate" />
                        <TranslateTransform x:Name="PlaneBobTranslate" />
                    </TransformGroup>
                </Grid.RenderTransform>

                <Ellipse x:Name="PlaneShadow"
                         Width="59"
                         Height="8"
                         Margin="16,44,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#42111624"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="PlaneShadowScale" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Canvas Width="92" Height="58">
                    <!-- Tail planes and wings are separate vector layers so
                         their subtle flex is animated independently. -->
                    <Path Fill="#FF6681E8"
                          Stroke="#A9D7E1FF"
                          StrokeThickness="0.8"
                          Data="M18,24 L8,10 L17,11 L31,23 Z" />
                    <Path Fill="#FF758EF0"
                          Stroke="#A9D7E1FF"
                          StrokeThickness="0.8"
                          Data="M19,29 L7,38 L18,37 L33,29 Z" />

                    <Path x:Name="PlaneWing"
                          Fill="#FF7392F5"
                          Stroke="#BFE3EBFF"
                          StrokeThickness="0.9"
                          RenderTransformOrigin="0.48,0.78"
                          Data="M40,23 L27,4 L38,5 L60,22 Z M46,30 L31,51 L41,50 L65,30 Z">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="WingFlexScale"
                                            ScaleX="1"
                                            ScaleY="1" />
                        </Path.RenderTransform>
                    </Path>

                    <Path Stroke="#D7F1F5FF"
                          StrokeThickness="1.1">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF536ACB" Offset="0" />
                                <GradientStop Color="#FF7998FF" Offset="0.48" />
                                <GradientStop Color="#FFB8CBFF" Offset="1" />
                            </LinearGradientBrush>
                        </Path.Fill>
                        <Path.Data>
                            M7,27
                            C21,22 43,20 66,20
                            C77,20 86,23 90,27
                            C85,32 76,34 66,34
                            C42,34 20,31 7,29 Z
                        </Path.Data>
                    </Path>

                    <Path Fill="#DDEDF3FF"
                          Data="M65,22 C73,21 80,23 84,26 L72,27 Z" />
                    <Ellipse Canvas.Left="61"
                             Canvas.Top="23"
                             Width="5"
                             Height="3"
                             Fill="#FF213151" />
                    <Ellipse Canvas.Left="68"
                             Canvas.Top="23"
                             Width="5"
                             Height="3"
                             Fill="#FF213151" />
                    <Ellipse Canvas.Left="75"
                             Canvas.Top="24"
                             Width="4"
                             Height="2.7"
                             Fill="#FF213151" />

                    <Ellipse Canvas.Left="48"
                             Canvas.Top="31"
                             Width="20"
                             Height="12"
                             Fill="#FF4259B5"
                             Stroke="#C4DCE6FF"
                             StrokeThickness="1" />
                    <Grid Canvas.Left="54"
                          Canvas.Top="33"
                          Width="9"
                          Height="9"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="EngineFanRotate" />
                        </Grid.RenderTransform>
                        <Ellipse Stroke="#DDECF2FF"
                                 StrokeThickness="0.7"
                                 Fill="#FF25345C" />
                        <Path Stroke="#EAF8FAFF"
                              StrokeThickness="0.65"
                              Data="M4.5,0.8 L4.5,8.2 M0.8,4.5 L8.2,4.5 M1.8,1.8 L7.2,7.2 M7.2,1.8 L1.8,7.2" />
                    </Grid>

                    <Ellipse x:Name="NavigationLight"
                             Canvas.Left="86"
                             Canvas.Top="26"
                             Width="5"
                             Height="5"
                             Fill="#FFFFD66E">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="7"
                                              ShadowDepth="0"
                                              Opacity="0.9"
                                              Color="#FFFFD66E" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Canvas.Left="9"
                             Canvas.Top="26"
                             Width="4"
                             Height="4"
                             Fill="#FF8FE3C0" />
                </Canvas>
            </Grid>
        </Grid>
    </Canvas>
</Window>
