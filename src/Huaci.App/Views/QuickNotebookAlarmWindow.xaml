<Window x:Class="Huaci.App.Views.QuickNotebookAlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Huaci 笔记闹铃"
        Width="306" Height="272"
        MinWidth="306" MinHeight="272"
        MaxWidth="306" MaxHeight="272"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        Loaded="Window_OnLoaded"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CompactWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource SettingsPanelBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="10">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="23" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                    <StackPanel Margin="11,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE823;"
                                   FontFamily="{StaticResource IconFont}"
                                   FontSize="14"
                                   Foreground="{StaticResource WarningBrush}" />
                        <TextBlock Margin="7,0,0,0"
                                   Text="设置闹铃"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Margin="6,1,0,0"
                                   Text="保存后显示在历史记录"
                                   FontSize="8.5"
                                   Foreground="{StaticResource TextWeakBrush}" />
                    </StackPanel>
                </Border>
                <Button Grid.Column="1"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="关闭"
                        AutomationProperties.Name="关闭闹铃设置"
                        Click="CloseButton_OnClick">
                    <TextBlock Text="&#xE711;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="11" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="9,2,9,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="82" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="112" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource SectionCard}"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="提醒内容"
                                   FontSize="9.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox x:Name="AlarmMessageTextBox"
                                 Grid.Row="1"
                                 Margin="0,4,0,0"
                                 Height="43"
                                 Padding="7,5"
                                 MaxLength="2000"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="闹铃提醒内容"
                                 ToolTip="默认使用当前笔记文字，可在这里缩短横幅文案" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource SectionCard}"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="17" />
                            <RowDefinition Height="29" />
                            <RowDefinition Height="25" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="提醒时间"
                                   FontSize="9.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <Grid Grid.Row="1" Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="126" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <DatePicker x:Name="AlarmDatePicker"
                                        Height="25"
                                        Margin="0,2,0,0"
                                        Padding="3,1"
                                        Background="#FFE7EAF0"
                                        Foreground="#FF25282E"
                                        BorderBrush="#60747B88"
                                        SelectedDateFormat="Short"
                                        AutomationProperties.Name="闹铃日期" />
                            <ComboBox x:Name="AlarmHourComboBox"
                                      Grid.Column="2"
                                      Height="25"
                                      Margin="0,2,0,0"
                                      Padding="4,2"
                                      Background="#FFE7EAF0"
                                      Foreground="#FF25282E"
                                      BorderBrush="#60747B88"
                                      ItemStringFormat="{}{0:00}"
                                      AutomationProperties.Name="闹铃小时" />
                            <TextBlock Grid.Column="3"
                                       Text=":"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="AlarmMinuteComboBox"
                                      Grid.Column="4"
                                      Height="25"
                                      Margin="0,2,0,0"
                                      Padding="4,2"
                                      Background="#FFE7EAF0"
                                      Foreground="#FF25282E"
                                      BorderBrush="#60747B88"
                                      ItemStringFormat="{}{0:00}"
                                      AutomationProperties.Name="闹铃分钟" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Height="21"
                                    MinHeight="21"
                                    Padding="3,1"
                                    FontSize="8.8"
                                    Content="+10 分钟"
                                    Tag="10"
                                    Click="QuickTimeButton_OnClick" />
                            <Button Grid.Column="2"
                                    Height="21"
                                    MinHeight="21"
                                    Padding="3,1"
                                    FontSize="8.8"
                                    Content="+30 分钟"
                                    Tag="30"
                                    Click="QuickTimeButton_OnClick" />
                            <Button Grid.Column="4"
                                    Height="21"
                                    MinHeight="21"
                                    Padding="3,1"
                                    FontSize="8.8"
                                    Content="+1 小时"
                                    Tag="60"
                                    Click="QuickTimeButton_OnClick" />
                        </Grid>

                        <Button x:Name="ScheduleAlarmButton"
                                Grid.Row="3"
                                Margin="0,2,0,0"
                                Height="21"
                                MinHeight="21"
                                Padding="6,2"
                                Style="{StaticResource AccentButton}"
                                Content="保存闹铃"
                                FontSize="9.3"
                                AutomationProperties.Name="保存笔记闹铃"
                                Click="ScheduleAlarmButton_OnClick" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="#48000000"
                    CornerRadius="0,0,9,9"
                    Padding="9,0">
                <TextBlock x:Name="AlarmStatusTextBlock"
                           Text="保存到本地 save\alarms.json，并显示在历史记录"
                           FontSize="8.5"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                           VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
            </Border>
        </Grid>
    </Border>
</Window>
